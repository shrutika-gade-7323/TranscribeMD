# ── TranscribeMD Environment Variables ──────────────────────────────────────
# Copy this file to .env and fill in your values

# Required: Anthropic API key for Claude (annotation + QA)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Google Gemini API key (for free-tier transcription annotations)
GEMINI_API_KEY=AIzaSy...
LLM_PROVIDER=gemini


# Transcription provider configuration (groq | openai)
TRANSCRIPTION_PROVIDER=groq

# Optional: transcription model (groq default: whisper-large-v3, openai default: whisper-1)
TRANSCRIPTION_MODEL=whisper-large-v3

# API keys for cloud transcription providers
GROQ_API_KEY=gsk_...
OPENAI_API_KEY=sk-proj-...

# Optional fallback provider in case primary provider fails (e.g. rate limits or API outage)
TRANSCRIPTION_FALLBACK_PROVIDER=openai

# Database (used by Docker Compose — leave defaults for local dev)
POSTGRES_DB=transcribemd
POSTGRES_USER=transcribemd
POSTGRES_PASSWORD=transcribemd123

# MinIO (object storage — leave defaults for local dev)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
